# ──────────────────────────────────────────────
# EduOS Backend — Environment Variables
# Copy this to .env and fill in the values
# ──────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
JWT_SIGNING_KEY=change-me-to-a-random-50-char-string

# Database — SQLite by default in dev (db.sqlite3). Use Postgres with docker-compose:
# USE_POSTGRES=true
USE_POSTGRES=false
DB_NAME=eduos_dev
DB_USER=eduos
DB_PASSWORD=eduos
DB_HOST=localhost
DB_PORT=5432

# Database — Read Replica (production only)
# DB_REPLICA_NAME=eduos
# DB_REPLICA_USER=eduos_readonly
# DB_REPLICA_PASSWORD=
# DB_REPLICA_HOST=replica.host
# DB_REPLICA_PORT=5432

# Redis — optional in dev (DRF throttling/cache use locmem unless USE_REDIS=true)
# USE_REDIS=true
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# CSRF (optional extra origins, comma-separated)
# CSRF_TRUSTED_ORIGINS=http://greenfield.localhost:3000

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=eduos-uploads
AWS_S3_REGION_NAME=ap-south-1

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# MSG91 (SMS)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=EDUOS

# Anthropic (AI)
ANTHROPIC_API_KEY=

# Email (production only)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Production
# ALLOWED_HOSTS=api.eduos.app,*.eduos.app
